{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:all": "npm run build && npm run build scheduler && npm run build notification",
    "predeploy": "if [ -d  dist ]; then rm -rf dist; fi && npm run build:all",
    "deploy": "scp -r pasdt@pasdt_new:~/sites/pasdtems/new_ems/dist pasdt@pasdt_new:~/sites/pasdtems/new_ems/backups/$(date '+%Y-%m-%d@%H:%M:%S')_backend && scp -r dist pasdt@pasdt_new:~/sites/pasdtems/new_ems/ ",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/backend/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "start:all": "npx concurrently \"npm run start:dev\" \"npm run start:dev conversation\" \"npm run start:dev scheduler\" \"npm run start:dev notification\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/backend/test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.729.0",
    "@aws-sdk/lib-storage": "^3.712.0",
    "@aws-sdk/s3-request-presigner": "^3.729.0",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/bullmq": "^10.2.0",
    "@nestjs/cache-manager": "^2.2.2",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "*",
    "@nestjs/microservices": "^10.3.10",
    "@nestjs/mongoose": "^10.0.10",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.4.1",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/websockets": "^10.4.1",
    "@redis/client": "^1.6.0",
    "@types/multer": "^1.4.12",
    "amqp-connection-manager": "^4.1.14",
    "amqplib": "^0.10.4",
    "aws-sdk": "^2.1692.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.0",
    "cache-manager-redis-store": "^3.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.3",
    "jwa": "^2.0.1",
    "jws": "^4.0.1",
    "mime-types": "^2.1.35",
    "moment": "^2.30.1",
    "mongoose": "^8.5.2",
    "nodemailer": "^6.9.14",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/aws-sdk": "^2.7.4",
    "@types/cron": "^2.4.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/nodemailer": "^6.4.15",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@lib/database(|/.*)$": "<rootDir>/libs/database/src/$1",
      "^@lib/config(|/.*)$": "<rootDir>/libs/config/src/$1",
      "^@lib/rmq(|/.*)$": "<rootDir>/libs/rmq/src/$1",
      "^@lib/common(|/.*)$": "<rootDir>/libs/common/src/$1",
      "^@lib/dto(|/.*)$": "<rootDir>/libs/dto/src/$1",
      "^@lib/guards(|/.*)$": "<rootDir>/libs/guards/src/$1",
      "^@lib/decorators(|/.*)$": "<rootDir>/libs/decorators/src/$1",
      "^@lib/token(|/.*)$": "<rootDir>/libs/token/src/$1",
      "^@lib/middlewares(|/.*)$": "<rootDir>/libs/middlewares/src/$1",
      "^@lib/interceptors(|/.*)$": "<rootDir>/libs/interceptors/src/$1",
      "^@app/dynamic-cron(|/.*)$": "<rootDir>/libs/dynamic-cron/src/$1",
      "^@app/file-upload(|/.*)$": "<rootDir>/libs/file-upload/src/$1",
      "^@app/libs/common/encrypt(|/.*)$": "<rootDir>/libs/libs/common/encrypt/src/$1",
      "^@app/common/encrypt(|/.*)$": "<rootDir>/libs/common/encrypt/src/$1",
      "^@app/common/src/encrypt(|/.*)$": "<rootDir>/libs/common/src/encrypt/src/$1",
      "^@lib/event(|/.*)$": "<rootDir>/libs/event/src/$1"
    }
  }
}
